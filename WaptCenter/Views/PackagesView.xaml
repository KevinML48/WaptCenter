<UserControl x:Class="WaptCenter.Views.PackagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="PackagesStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#38506D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                    <Setter Property="Foreground" Value="#A03333" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PackagesTechnicalDetailsExpanderStyle" TargetType="Expander">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,14,0,0" />
            <Setter Property="IsExpanded" Value="False" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TechnicalDetails}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PackagesTechnicalDetailsStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="Background" Value="#F7FBFF" />
            <Setter Property="Foreground" Value="#41546D" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="110" />
            <Setter Property="MaxHeight" Value="220" />
        </Style>

        <Style x:Key="PackagesProgressStyle" TargetType="ProgressBar">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoadingPackages}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsProgressStyle" TargetType="ProgressBar">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.IsLoadingMachines}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#38506D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.IsStatusError}" Value="True">
                    <Setter Property="Foreground" Value="#A03333" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsTechnicalDetailsExpanderStyle" TargetType="Expander">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="IsExpanded" Value="False" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.TechnicalDetails}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsTechnicalDetailsStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="Background" Value="#FFFDF5" />
            <Setter Property="Foreground" Value="#41546D" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="110" />
            <Setter Property="MaxHeight" Value="220" />
        </Style>

        <Style x:Key="MachineDetailsSummaryTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.MatchTypeSummaryMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsComplianceSummaryTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="#214E35" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.ComplianceSummaryMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsOuSummaryTextStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="#41546D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.OuSummaryMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsOuBreakdownBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#F7FBFF" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.HasOuComplianceBreakdown}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MachineDetailsWarningBorderStyle" TargetType="Border">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,12,0,0" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Background" Value="#FFF6DD" />
            <Setter Property="BorderBrush" Value="#E5C46D" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding PackageDetails.MatchTypeWarningMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PageCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="PageCardTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PageCardSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#5E6B84" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SummaryCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7FBFF" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="Width" Value="280" />
        </Style>

        <Style x:Key="SummaryCardLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#5E6B84" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SummaryCardValueTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="190" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Background" Value="#1F5A9A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="ReadableDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEF4FA" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="ReadableDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ReadableDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFCFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WrappingGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ReadableDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="RowStyle" Value="{StaticResource ReadableDataGridRowStyle}" />
            <Setter Property="CellStyle" Value="{StaticResource ReadableDataGridCellStyle}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource ReadableDataGridHeaderStyle}" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="MinRowHeight" Value="38" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  Background="#F4F7FB"
                  Padding="22">
        <StackPanel>
            <Border Style="{StaticResource PageCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                                   Text="Inventaire des paquets cd48" />
                        <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                                   Text="Chargez les paquets via le bridge Python, sélectionnez un package_id, puis consultez les machines associées, leur conformité et leur répartition par OU dans une page lisible et scrollable." />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right">
                        <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding LoadPackagesCommand}"
                                Content="Charger les paquets" />

                        <ProgressBar Height="6"
                                     Margin="0,14,0,0"
                                     IsIndeterminate="True"
                                     Style="{StaticResource PackagesProgressStyle}" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.6*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SummaryCardBorderStyle}"
                                Width="Auto"
                                Margin="0,0,14,0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                           Text="Résumé du chargement des paquets" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource PackagesStatusTextStyle}"
                                           Text="{Binding StatusMessage}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1"
                                Style="{StaticResource SummaryCardBorderStyle}"
                                Width="Auto"
                                Margin="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                           Text="Lecture de la page" />
                                <TextBlock Style="{StaticResource SummaryCardValueTextStyle}"
                                           Text="Les détails techniques restent repliés plus bas. La page se parcourt verticalement, tandis que chaque grille garde son propre scroll interne." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Style="{StaticResource PageCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                               Text="Liste des paquets" />
                    <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                               Text="Le tableau garde une grande zone de lecture, des colonnes redimensionnables et un scroll interne pour parcourir confortablement tous les résultats cd48." />

                    <DataGrid Margin="0,18,0,0"
                              Height="360"
                              MinHeight="300"
                              Style="{StaticResource ReadableDataGridStyle}"
                              ItemsSource="{Binding Packages}"
                              SelectedItem="{Binding SelectedPackage, Mode=TwoWay}"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PackageId" Binding="{Binding PackageId}" Width="2*" MinWidth="190" />
                            <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="1.5*" MinWidth="170" />
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="150" MinWidth="130" />
                            <DataGridTextColumn Header="Maturité" Binding="{Binding Maturity}" Width="130" MinWidth="120" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="3.2*" MinWidth="320">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappingGridTextStyle}" />
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                                   Text="Détail du paquet sélectionné" />
                        <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                                   Text="{Binding PackageDetails.SelectedPackageSummary}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Width="320">
                        <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding PackageDetails.ReloadCommand}"
                                Content="Recharger les machines" />

                        <TextBlock Margin="0,14,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#41546D"
                                   Text="Filtrer par OU" />

                        <ComboBox Height="38"
                                  Margin="0,8,0,0"
                                  ItemsSource="{Binding PackageDetails.AvailableOuFilters}"
                                  SelectedItem="{Binding PackageDetails.SelectedOuFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <ProgressBar Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Height="6"
                                 Margin="0,18,0,0"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MachineDetailsProgressStyle}" />

                    <WrapPanel Grid.Row="2"
                               Grid.ColumnSpan="2"
                               Margin="0,18,0,0">
                        <Border Style="{StaticResource SummaryCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                           Text="État du chargement machines" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MachineDetailsStatusTextStyle}"
                                           Text="{Binding PackageDetails.StatusMessage}" />
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SummaryCardBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PackageDetails.ComplianceSummaryMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                           Text="Conformité" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MachineDetailsComplianceSummaryTextStyle}"
                                           Text="{Binding PackageDetails.ComplianceSummaryMessage}" />
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SummaryCardBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PackageDetails.MatchTypeSummaryMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                           Text="Type de correspondance" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MachineDetailsSummaryTextStyle}"
                                           Text="{Binding PackageDetails.MatchTypeSummaryMessage}" />
                            </StackPanel>
                        </Border>

                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SummaryCardBorderStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding PackageDetails.OuSummaryMessage}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                           Text="Visibilité par OU" />
                                <TextBlock Margin="0,8,0,0"
                                           Style="{StaticResource MachineDetailsOuSummaryTextStyle}"
                                           Text="{Binding PackageDetails.OuSummaryMessage}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <Border Grid.Row="3"
                            Grid.ColumnSpan="2"
                            Style="{StaticResource MachineDetailsWarningBorderStyle}">
                        <TextBlock Foreground="#7A5608"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   Text="{Binding PackageDetails.MatchTypeWarningMessage}" />
                    </Border>
                </Grid>
            </Border>

            <Border Style="{StaticResource PageCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                               Text="Machines associées" />
                    <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                               Text="La grille machines garde une grande surface de lecture, des colonnes redimensionnables et un scroll horizontal si la largeur visible ne suffit pas." />

                    <DataGrid Margin="0,18,0,0"
                              Height="460"
                              MinHeight="400"
                              Style="{StaticResource ReadableDataGridStyle}"
                              ItemsSource="{Binding PackageDetails.FilteredMachines}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Hostname" Binding="{Binding Hostname}" Width="1.2*" MinWidth="160" />
                            <DataGridTextColumn Header="FQDN" Binding="{Binding Fqdn}" Width="1.7*" MinWidth="230" />
                            <DataGridTextColumn Header="OU / Organisation" Binding="{Binding OrganizationDisplay}" Width="2.2*" MinWidth="300">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappingGridTextStyle}" />
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Version installée" Binding="{Binding InstalledVersion}" Width="160" MinWidth="150" />
                            <DataGridTextColumn Header="Type de correspondance" Binding="{Binding MatchTypeDisplayLabel}" Width="190" MinWidth="180" />
                            <DataGridTemplateColumn Header="Statut conformité" Width="180" MinWidth="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,4"
                                                CornerRadius="10"
                                                BorderThickness="1"
                                                HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FFF1D9" />
                                                    <Setter Property="BorderBrush" Value="#D7942D" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ComplianceStatus}" Value="compliant">
                                                            <Setter Property="Background" Value="#E3F5E7" />
                                                            <Setter Property="BorderBrush" Value="#5BA46B" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding ComplianceStatus}" Value="non_compliant">
                                                            <Setter Property="Background" Value="#F9E1E1" />
                                                            <Setter Property="BorderBrush" Value="#C45151" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding ComplianceStatusDisplayLabel}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#8A5A07" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ComplianceStatus}" Value="compliant">
                                                                <Setter Property="Foreground" Value="#215B34" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding ComplianceStatus}" Value="non_compliant">
                                                                <Setter Property="Foreground" Value="#922F2F" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}" Width="180" MinWidth="170" />
                            <DataGridTextColumn Header="Etat hôte" Binding="{Binding Status}" Width="150" MinWidth="140" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border>
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource PageCardBorderStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding PackageDetails.HasOuComplianceBreakdown}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                               Text="Répartition par OU" />
                    <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                               Text="Cette section isole les regroupements par OU pour éviter de compresser les détails du paquet et la grille machines." />

                    <Border Style="{StaticResource MachineDetailsOuBreakdownBorderStyle}"
                            Margin="0,18,0,0">
                        <ScrollViewer MaxHeight="260"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding PackageDetails.OuComplianceBreakdownLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="#41546D"
                                                   FontSize="13"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageCardBorderStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                               Text="Détails techniques" />
                    <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                               Text="Les diagnostics restent disponibles sans occuper l’espace principal. Chaque section reste fermée par défaut et ne s’ouvre qu’en cas de besoin." />

                    <Expander Header="Chargement des paquets"
                              Style="{StaticResource PackagesTechnicalDetailsExpanderStyle}">
                        <TextBox Style="{StaticResource PackagesTechnicalDetailsStyle}"
                                 Text="{Binding TechnicalDetails}" />
                    </Expander>

                    <Expander Header="Chargement des machines"
                              Style="{StaticResource MachineDetailsTechnicalDetailsExpanderStyle}">
                        <TextBox Style="{StaticResource MachineDetailsTechnicalDetailsStyle}"
                                 Text="{Binding PackageDetails.TechnicalDetails}" />
                    </Expander>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>