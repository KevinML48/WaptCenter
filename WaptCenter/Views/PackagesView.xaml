<UserControl x:Class="WaptCenter.Views.PackagesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="PackagesStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#38506D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                    <Setter Property="Foreground" Value="#A03333" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PackagesTechnicalDetailsStyle" TargetType="TextBox">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,14,0,0" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="Background" Value="#F7FBFF" />
            <Setter Property="Foreground" Value="#41546D" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="90" />
            <Setter Property="MaxHeight" Value="180" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TechnicalDetails}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PackagesProgressStyle" TargetType="ProgressBar">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoadingPackages}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Paquets WAPT dont package_id contient cd48"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1D2940" />
            <TextBlock Text="Le chargement passe par un bridge Python qui s'appuie sur l'outillage WAPT local, retourne du JSON au desktop, puis conserve uniquement les paquets dont l'identifiant technique package_id contient cd48, sans filtrer sur le nom d'affichage."
                       Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       Foreground="#5E6B84"
                       FontSize="13" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,24,0,18">
            <StackPanel Orientation="Horizontal">
                <Button Width="180"
                        Height="40"
                        Padding="18,10"
                        Background="#1F5A9A"
                        BorderThickness="0"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Command="{Binding LoadPackagesCommand}"
                        Content="Charger les paquets" />
            </StackPanel>

            <ProgressBar Height="6"
                         Margin="0,14,0,0"
                         IsIndeterminate="True"
                         Style="{StaticResource PackagesProgressStyle}" />

            <TextBlock Margin="0,14,0,0"
                       Style="{StaticResource PackagesStatusTextStyle}"
                       Text="{Binding StatusMessage}" />

            <TextBox Style="{StaticResource PackagesTechnicalDetailsStyle}"
                     Text="{Binding TechnicalDetails}" />
        </StackPanel>

        <DataGrid Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  ItemsSource="{Binding Packages}"
                  RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal"
                  BorderBrush="#D9E0EA"
                  BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Package ID" Binding="{Binding PackageId}" Width="220" />
                <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="180" />
                <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="160" />
                <DataGridTextColumn Header="Maturite" Binding="{Binding Maturity}" Width="120" />
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextWrapping" Value="Wrap" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
