<Window x:Class="WaptCenter.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:WaptCenter.ViewModels"
        xmlns:views="clr-namespace:WaptCenter.Views"
        mc:Ignorable="d"
        Title="WaptCenter"
        Width="1100"
        Height="700"
        MinWidth="920"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#EEF2F8">
    <Window.Resources>
        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:PackagesViewModel}">
            <views:PackagesView />
        </DataTemplate>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="180" />
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#1F2A44" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#1F2A44" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock Text="WaptCenter"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold" />
                    <TextBlock Text="Preparation locale de la connexion WAPT"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               Foreground="#C9D3E8"
                               FontSize="13" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,32,0,0" VerticalAlignment="Top">
                    <Button Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowDashboardCommand}"
                        Content="Tableau de bord" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowSettingsCommand}"
                        Content="Parametres" />

                    <Button Style="{StaticResource SidebarButtonStyle}"
                        Command="{Binding ShowPackagesCommand}"
                        Content="Paquets" />
                </StackPanel>

                <TextBlock Grid.Row="2"
                           Foreground="#9DACCC"
                           FontSize="12"
                           Text=".NET 8 | WPF | MVVM" />
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Background="#F7FBFF"
                    CornerRadius="18"
                    Padding="24"
                    Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock Text="{Binding CurrentSectionTitle}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1D2940" />
                    <TextBlock Text="{Binding CurrentSectionDescription}"
                               Margin="0,8,0,0"
                               TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#5E6B84" />
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    CornerRadius="18"
                    Padding="24">
                <ContentControl Content="{Binding CurrentViewModel}" />
            </Border>
        </Grid>
    </Grid>
</Window>