<UserControl x:Class="WaptCenter.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="DashboardStatusTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#38506D" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                    <Setter Property="Foreground" Value="#A03333" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardProgressStyle" TargetType="ProgressBar">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLoadingDashboard}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardTechnicalDetailsExpanderStyle" TargetType="Expander">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,16,0,0" />
            <Setter Property="IsExpanded" Value="False" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TechnicalDetails}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DashboardTechnicalDetailsStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="Background" Value="#F7FBFF" />
            <Setter Property="Foreground" Value="#41546D" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="120" />
            <Setter Property="MaxHeight" Value="260" />
        </Style>

        <Style x:Key="PageCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
        </Style>

        <Style x:Key="PageCardTitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PageCardSubtitleTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#5E6B84" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SummaryCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#F7FBFF" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="Width" Value="230" />
        </Style>

        <Style x:Key="SummaryCardLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#5E6B84" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SummaryCardValueTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,8,0,0" />
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="SummaryCardHintTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#5E6B84" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="FilterLabelTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#41546D" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="220" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Background" Value="#1F5A9A" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="Padding" Value="18,10" />
            <Setter Property="Background" Value="#FFF6DD" />
            <Setter Property="BorderBrush" Value="#E5C46D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#7A5608" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>

        <Style x:Key="ReadableDataGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EEF4FA" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style x:Key="ReadableDataGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ReadableDataGridRowStyle" TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFCFF" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WrappingGridTextStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ReadableDataGridStyle" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="BorderBrush" Value="#D9E0EA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1D2940" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="RowStyle" Value="{StaticResource ReadableDataGridRowStyle}" />
            <Setter Property="CellStyle" Value="{StaticResource ReadableDataGridCellStyle}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource ReadableDataGridHeaderStyle}" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Visible" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
            <Setter Property="MinRowHeight" Value="38" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Style="{StaticResource PageCardBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                                   Text="Tableau de bord cd48" />
                        <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                                   Text="Chargez une synthese globale des paquets cd48, des machines associees et des regroupements par OU sans quitter l'architecture bridge existante." />

                        <StackPanel Margin="0,18,0,0"
                                    Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryActionButtonStyle}"
                                    Command="{Binding RefreshDashboardCommand}"
                                    Content="Actualiser le tableau de bord" />
                            <Button Margin="12,0,0,0"
                                    Style="{StaticResource SecondaryActionButtonStyle}"
                                    Command="{Binding CancelLoadCommand}"
                                    Content="Annuler" />
                        </StackPanel>

                        <ProgressBar Height="7"
                                     Margin="0,16,0,0"
                                     Minimum="0"
                                     Maximum="{Binding TotalPackageCount}"
                                     Value="{Binding AnalyzedPackageCount}"
                                     Style="{StaticResource DashboardProgressStyle}" />

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Style="{StaticResource FilterLabelTextStyle}"
                                           Text="Recherche package_id / nom" />
                                <TextBox Height="38"
                                         Margin="0,8,0,0"
                                         Padding="10,6"
                                         Text="{Binding PackageSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Margin="0,0,14,0">
                                <TextBlock Style="{StaticResource FilterLabelTextStyle}"
                                           Text="Filtre OU" />
                                <ComboBox Height="38"
                                          Margin="0,8,0,0"
                                          ItemsSource="{Binding AvailableOuFilters}"
                                          SelectedItem="{Binding SelectedOuFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource FilterLabelTextStyle}"
                                           Text="Statut conformité" />
                                <ComboBox Height="38"
                                          Margin="0,8,0,0"
                                          ItemsSource="{Binding ComplianceFilters}"
                                          SelectedItem="{Binding SelectedComplianceFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,10,0,0"
                                   Style="{StaticResource SummaryCardHintTextStyle}"
                                   Text="Les filtres s'appliquent aux deux grilles de synthese et aux exports CSV. Les cartes de resume restent globales." />
                    </StackPanel>

                    <Border Grid.Column="1"
                            Margin="18,0,0,0"
                            Style="{StaticResource SummaryCardBorderStyle}"
                            Width="Auto">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                       Text="État du chargement" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource DashboardStatusTextStyle}"
                                       Text="{Binding StatusMessage}" />
                            <TextBlock Margin="0,10,0,0"
                                       Style="{StaticResource SummaryCardLabelTextStyle}"
                                       Text="Paquet en cours" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource SummaryCardValueTextStyle}"
                                       FontSize="16"
                                       Text="{Binding CurrentPackageLabel}" />
                            <TextBlock Style="{StaticResource SummaryCardHintTextStyle}"
                                       Text="{Binding AnalyzedPackageCount, StringFormat={}{0} paquet(s) traites}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <WrapPanel>
                <Border Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                   Text="Paquets cd48" />
                        <TextBlock Style="{StaticResource SummaryCardValueTextStyle}"
                                   Text="{Binding TotalPackageCount}" />
                        <TextBlock Style="{StaticResource SummaryCardHintTextStyle}"
                                   Text="Nombre total de paquets remontes par le bridge packages." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                   Text="Machines analysees" />
                        <TextBlock Style="{StaticResource SummaryCardValueTextStyle}"
                                   Text="{Binding TotalMachineCount}" />
                        <TextBlock Style="{StaticResource SummaryCardHintTextStyle}"
                                   Text="Machines distinctes consolidees sur l'ensemble des paquets analyses." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                   Text="OU distinctes" />
                        <TextBlock Style="{StaticResource SummaryCardValueTextStyle}"
                                   Text="{Binding TotalDistinctOuCount}" />
                        <TextBlock Style="{StaticResource SummaryCardHintTextStyle}"
                                   Text="Groupes OU / organisation distincts visibles dans le dashboard." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                   Text="Machines conformes" />
                        <TextBlock Style="{StaticResource SummaryCardValueTextStyle}"
                                   Text="{Binding CompliantMachineCount}" />
                        <TextBlock Style="{StaticResource SummaryCardHintTextStyle}"
                                   Text="Machines ayant au moins une installation exacte conforme." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                   Text="Machines inconnues / fallback" />
                        <TextBlock Style="{StaticResource SummaryCardValueTextStyle}"
                                   Text="{Binding UnknownMachineCount}" />
                        <TextBlock Style="{StaticResource SummaryCardHintTextStyle}"
                                   Text="Machines uniquement observees via fallback ou sans statut plus precis." />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SummaryCardLabelTextStyle}"
                                   Text="Machines non conformes" />
                        <TextBlock Style="{StaticResource SummaryCardValueTextStyle}"
                                   Text="{Binding NonCompliantMachineCount}" />
                        <TextBlock Style="{StaticResource SummaryCardHintTextStyle}"
                                   Text="Compteur affiche si le flux remonte des statuts non conformes." />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border Style="{StaticResource PageCardBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                                       Text="Synthèse par paquet" />
                            <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                                       Text="Chaque ligne visible est recalculee a partir des machines qui passent les filtres actifs du dashboard." />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Margin="16,0,0,0"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding ExportPackageSummaryCsvCommand}"
                                Content="Exporter synthèse paquets" />
                    </Grid>

                    <DataGrid Margin="0,18,0,0"
                              Height="320"
                              MinHeight="280"
                              Style="{StaticResource ReadableDataGridStyle}"
                              ItemsSource="{Binding PackageSummaries}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PackageId" Binding="{Binding PackageId}" Width="1.5*" MinWidth="180" />
                            <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="1.3*" MinWidth="180">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappingGridTextStyle}" />
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="140" MinWidth="130" />
                            <DataGridTextColumn Header="Machines" Binding="{Binding MachineCount}" Width="110" MinWidth="100" />
                            <DataGridTextColumn Header="Conformes" Binding="{Binding CompliantCount}" Width="110" MinWidth="100" />
                            <DataGridTextColumn Header="Inconnues" Binding="{Binding UnknownCount}" Width="110" MinWidth="100" />
                            <DataGridTextColumn Header="Non conformes" Binding="{Binding NonCompliantCount}" Width="130" MinWidth="120" />
                            <DataGridTextColumn Header="OU distinctes" Binding="{Binding DistinctOuCount}" Width="120" MinWidth="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageCardBorderStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                                       Text="Synthèse par OU" />
                            <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                                       Text="Les lignes visibles agrègent uniquement les machines et paquets qui passent les filtres actifs du dashboard." />
                        </StackPanel>

                        <Button Grid.Column="1"
                                Margin="16,0,0,0"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Command="{Binding ExportOuSummaryCsvCommand}"
                                Content="Exporter synthèse OU" />
                    </Grid>

                    <DataGrid Margin="0,18,0,0"
                              Height="320"
                              MinHeight="280"
                              Style="{StaticResource ReadableDataGridStyle}"
                              ItemsSource="{Binding OuSummaries}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="OU / Organisation" Binding="{Binding OrganizationDisplay}" Width="2.4*" MinWidth="320">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource WrappingGridTextStyle}" />
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Machines" Binding="{Binding MachineCount}" Width="110" MinWidth="100" />
                            <DataGridTextColumn Header="Paquets concernés" Binding="{Binding PackageCount}" Width="140" MinWidth="130" />
                            <DataGridTextColumn Header="Conformes" Binding="{Binding CompliantCount}" Width="110" MinWidth="100" />
                            <DataGridTextColumn Header="Inconnues" Binding="{Binding UnknownCount}" Width="110" MinWidth="100" />
                            <DataGridTextColumn Header="Non conformes" Binding="{Binding NonCompliantCount}" Width="130" MinWidth="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource PageCardBorderStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageCardTitleTextStyle}"
                               Text="Détails techniques" />
                    <TextBlock Style="{StaticResource PageCardSubtitleTextStyle}"
                               Text="Les détails du chargement global restent repliés pour garder un tableau de bord lisible par défaut." />

                    <Expander Header="Analyse du tableau de bord"
                              Style="{StaticResource DashboardTechnicalDetailsExpanderStyle}">
                        <TextBox Style="{StaticResource DashboardTechnicalDetailsStyle}"
                                 Text="{Binding TechnicalDetails}" />
                    </Expander>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>