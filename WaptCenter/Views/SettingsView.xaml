<UserControl x:Class="WaptCenter.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,16,14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#31415B" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="#FBFCFE" />
            <Setter Property="BorderBrush" Value="#CCD4E0" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="#FBFCFE" />
            <Setter Property="BorderBrush" Value="#CCD4E0" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="StatusMessageStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Foreground" Value="#237A3B" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding StatusMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConnectionMessageStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#2D5B88" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionTestMessage}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsConnectionSuccessful}" Value="True">
                    <Setter Property="Foreground" Value="#1F6B3A" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsConnectionSuccessful}" Value="False">
                    <Setter Property="Foreground" Value="#A03333" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConnectionTechnicalDetailsStyle" TargetType="TextBlock">
            <Setter Property="Visibility" Value="Visible" />
            <Setter Property="Margin" Value="0,10,0,0" />
            <Setter Property="Foreground" Value="#5E6B84" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding ConnectionTechnicalDetails}" Value="">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Parametres WAPT"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#1D2940" />
                <TextBlock Text="Cette premiere etape enregistre la configuration locale qui servira aux futurs tests et chargements WAPT."
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="#5E6B84"
                           FontSize="13" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,28,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="URL du serveur WAPT" />
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding ServerUrl, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Certificat client (.crt ou .pem)" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding ClientCertPath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Cle privee PEM optionnelle" />
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding ClientKeyPath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Fichier PEM (prioritaire sur PKCS12)" />
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding PemPath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Certificat PKCS12 (.p12 / .pfx)" />
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding Pkcs12Path, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Mot de passe du certificat" />
                <PasswordBox x:Name="CertPasswordBox"
                             Grid.Row="5"
                             Grid.Column="1"
                             PasswordChanged="CertPasswordBox_OnPasswordChanged" />

                <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Certificat serveur attendu" />
                <TextBox Grid.Row="6" Grid.Column="1"
                         Text="{Binding CaCertPath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Timeout (secondes)" />
                <TextBox Grid.Row="7" Grid.Column="1"
                         Text="{Binding TimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="8" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Python executable" />
                <TextBox Grid.Row="8" Grid.Column="1"
                         Text="{Binding PythonExecutablePath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="9" Grid.Column="0" Style="{StaticResource FieldLabelStyle}" Text="Script bridge Python" />
                <TextBox Grid.Row="9" Grid.Column="1"
                         Text="{Binding BridgeScriptPath, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <StackPanel Grid.Row="2" Margin="0,20,0,0">
                <CheckBox IsChecked="{Binding VerifySsl}"
                          Content="Activer la verification SSL" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Width="180"
                            Height="40"
                            Margin="0,0,12,0"
                            Padding="18,10"
                            Background="#1F5A9A"
                            BorderThickness="0"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Command="{Binding TestConnectionCommand}"
                            Content="Tester la connexion .NET" />

                    <Button Width="150"
                            Height="40"
                            Padding="18,10"
                            Background="#1F7A53"
                            BorderThickness="0"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Command="{Binding SaveCommand}"
                            Content="Enregistrer" />
                </StackPanel>

                <TextBlock Margin="0,16,0,0"
                           Style="{StaticResource StatusMessageStyle}"
                           Text="{Binding StatusMessage}" />

                <TextBlock Margin="0,12,0,0"
                           Style="{StaticResource ConnectionMessageStyle}"
                           Text="{Binding ConnectionTestMessage}" />

                <TextBlock Style="{StaticResource ConnectionTechnicalDetailsStyle}"
                           Text="{Binding ConnectionTechnicalDetails}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>